# Пример переменных окружения PartsPrice Hub.
# Скопируйте в .env и заполните значения:  cp .env.example .env

# Токен Telegram-бота от @BotFather.
# Можно оставить пустым — тогда поднимется только REST API без бота.
BOT_TOKEN=

# Строка подключения к БД (асинхронный SQLAlchemy).
# SQLite (по умолчанию для локальной разработки):
DATABASE_URL=sqlite+aiosqlite:///./partsprice.db
# PostgreSQL (пример; для docker-compose.postgres.yml):
# DATABASE_URL=postgresql+asyncpg://user:password@db:5432/partsprice

# Секрет доступа к REST API. Передаётся клиентом в заголовке X-API-Key.
# Задайте длинное случайное значение (в проде — не 'change-me').
API_SECRET=change-me

# (Необязательно) Отдельный секрет для админских операций.
# Если задан — админом считается ТОЛЬКО владелец этого ключа
#   (запрос с заголовком  X-API-Key: <ADMIN_API_SECRET>),
# а связка «общий API_SECRET + X-Role: admin» админ-доступа больше не даёт.
# Если пусто — сохраняется прежнее поведение (общий ключ + X-Role: admin).
ADMIN_API_SECRET=

# Telegram ID администратора (целое число).
# Из него scripts/seed создаёт пользователя-админа.
ADMIN_TELEGRAM_ID=0

# Уровень логирования: DEBUG / INFO / WARNING / ERROR.
LOG_LEVEL=INFO
